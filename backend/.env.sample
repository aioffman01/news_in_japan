# ==============================================================================
# NewsInJapan FastAPI Backend Environment Configuration Template
# ==============================================================================
# Instructions:
# 1. Copy this file to a new file named '.env' in the same directory.
# 2. Update the values below with your actual API keys, ports, and database credentials.
# 3. DO NOT commit your actual '.env' file containing real secrets to version control.
# ==============================================================================

# 1. FastAPI Server Configurations
BACKEND_HOST=0.0.0.0
BACKEND_PORT=9001

# 2. Database Connection URL (Supabase PostgreSQL Recommended)
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
DATABASE_URL=postgresql://postgres.yourdbuser:YourSecurePassword123!@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# 3. Google Gemini Generative AI API Key
# Get your API key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=AIzaSyC7tiUE1ow5h4fVMAvbzyqedFY41Hp37GI_example

# 4. Security Configuration
# Used for encrypting and validating dashboard auth tokens. Change to a long random secret key.
JWT_SECRET=super_secret_dashboard_token_signing_key_9999
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 5. Default Dashboard Administrator Access Password
# This is the password required to access the dashboard on port 8001
DASHBOARD_PASSWORD=news1234
